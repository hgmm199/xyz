/* ── RESET ── */
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', sans-serif;
  background: #0f0f0f;
  color: #f0f0f0;
  min-height: 100vh;
}

/* ── NAV ── */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 24px;
  background: #1a1a1a;
  border-bottom: 1px solid #2a2a2a;
  position: sticky;
  top: 0;
  z-index: 100;
}
.logo {
  font-size: 1.3rem;
  font-weight: 700;
  color: #4ade80;
  letter-spacing: 1px;
}
.nav-links { display: flex; gap: 12px; }
.nav-links button {
  padding: 8px 20px;
  border-radius: 8px;
  font-size: 0.9rem;
  cursor: pointer;
  border: none;
  transition: all 0.2s;
}
.btn-login {
  background: transparent;
  border: 1px solid #4ade80 !important;
  color: #4ade80;
}
.btn-login:hover { background: #4ade8022; }
.btn-register { background: #4ade80; color: #0f0f0f; font-weight: 600; }
.btn-register:hover { background: #22c55e; }
.btn-nav-profile {
  padding: 8px 18px;
  background: #1e1e1e;
  border: 1px solid #333;
  color: #aaa;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.9rem;
  transition: all 0.2s;
}
.btn-nav-profile:hover { border-color: #4ade80; color: #4ade80; }
.btn-logout {
  padding: 8px 20px;
  background: #f87171;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
}
.btn-admin-file {
  padding: 8px 20px;
  background: #fbbf24;
  color: #0f0f0f;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 700;
  font-size: 0.9rem;
  transition: background 0.2s;
}
.btn-admin-file:hover { background: #f59e0b; }

/* ── HERO ── */
.hero { text-align: center; padding: 80px 20px 60px; }
.hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.2; }
.hero h1 span { color: #4ade80; }
.hero p { margin-top: 16px; color: #888; font-size: 1.1rem; }
.hero-cta {
  margin-top: 32px;
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}
.hero-cta button {
  padding: 12px 28px;
  border-radius: 10px;
  font-size: 1rem;
  cursor: pointer;
  border: none;
  font-weight: 600;
  transition: all 0.2s;
}
.cta-primary { background: #4ade80; color: #0f0f0f; }
.cta-primary:hover { background: #22c55e; transform: translateY(-1px); }
.cta-secondary { background: #1e1e1e; color: #ccc; border: 1px solid #333; }

/* ── MODAL OVERLAY ── */
.overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: #000000cc;
  z-index: 200;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.overlay.active { display: flex; }

.modal {
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 16px;
  padding: 32px;
  width: 100%;
  max-width: 420px;
  position: relative;
  animation: pop 0.2s ease;
}
@keyframes pop {
  from { transform: scale(0.95); opacity: 0; }
  to   { transform: scale(1);    opacity: 1; }
}
.modal h2 { font-size: 1.4rem; margin-bottom: 24px; color: #f0f0f0; }
.modal .close {
  position: absolute;
  top: 16px; right: 20px;
  background: none; border: none;
  color: #666; font-size: 1.4rem;
  cursor: pointer;
}
.modal .close:hover { color: #fff; }

/* ── FORM FIELDS ── */
.field { margin-bottom: 16px; }
.field label { display: block; font-size: 0.82rem; color: #888; margin-bottom: 6px; }
.field input {
  width: 100%;
  padding: 10px 14px;
  background: #111;
  border: 1px solid #333;
  border-radius: 8px;
  color: #f0f0f0;
  font-size: 0.95rem;
  outline: none;
  transition: border 0.2s;
}
.field input:focus { border-color: #4ade80; }

.modal-submit {
  width: 100%;
  padding: 12px;
  background: #4ade80;
  color: #0f0f0f;
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  margin-top: 8px;
  transition: background 0.2s;
}
.modal-submit:hover { background: #22c55e; }

.switch-link {
  text-align: center;
  margin-top: 16px;
  font-size: 0.85rem;
  color: #666;
}
.switch-link span { color: #4ade80; cursor: pointer; text-decoration: underline; }

.msg { margin-top: 12px; font-size: 0.85rem; text-align: center; }
.msg.error   { color: #f87171; }
.msg.success { color: #4ade80; }

/* ── DASHBOARD ── */
.dashboard { display: none; padding: 60px 20px; text-align: center; }
.dashboard.active { display: block; }
.dashboard h2 { font-size: 1.8rem; }
.dashboard h2 span { color: #4ade80; }
.dashboard-sub { color: #888; margin-top: 6px; font-size: 0.95rem; }

/* ── TOKEN PANEL ── */
.token-panel {
  margin: 32px auto 0;
  max-width: 480px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.token-field label {
  display: block;
  font-size: 0.78rem;
  color: #4ade80;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
  font-weight: 600;
}
.token-field input {
  width: 100%;
  padding: 10px 14px;
  background: #111;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  color: #f0f0f0;
  font-size: 0.95rem;
  outline: none;
  transition: border 0.2s;
  font-family: 'Courier New', monospace;
}
.token-field input:focus { border-color: #4ade80; }

.btn-save {
  width: 100%;
  padding: 12px;
  background: #4ade80;
  color: #0f0f0f;
  border: none;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  margin-top: 4px;
  transition: background 0.2s;
}
.btn-save:hover { background: #22c55e; }

.btn-goto-profile {
  width: 100%;
  padding: 12px;
  background: #1e1e1e;
  color: #4ade80;
  border: 1px solid #4ade80;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.2s;
  display: none;
}
.btn-goto-profile:hover { background: #4ade8022; }
.btn-goto-profile.visible { display: block; }

.token-msg {
  font-size: 0.85rem;
  text-align: center;
  min-height: 20px;
  margin-top: 4px;
}
.token-msg.success { color: #4ade80; }
.token-msg.error   { color: #f87171; }

/* ── INV TOGGLE ── */
.inv-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4px;
}
.inv-toggle-row label {
  font-size: 0.78rem;
  color: #4ade80;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 600;
}
.toggle-switch {
  width: 46px;
  height: 24px;
  border-radius: 999px;
  background: #333;
  border: none;
  position: relative;
  cursor: pointer;
  padding: 0;
  transition: background 0.2s;
}
.toggle-switch.on { background: #4ade80; }
.toggle-dot {
  position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: #f0f0f0;
  transition: transform 0.2s;
}
.toggle-switch.on .toggle-dot { transform: translateX(22px); background: #0f0f0f; }

/* ── RPC PANEL ── */
.rpc-panel {
  margin: 24px auto 0;
  max-width: 480px;
  border: 1px solid #2a2a2a;
  border-radius: 10px;
  overflow: hidden;
}
.rpc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  background: #1a1a1a;
  cursor: pointer;
  font-weight: 600;
  color: #f0f0f0;
  user-select: none;
}
.rpc-arrow { color: #4ade80; }
.rpc-body {
  max-height: 0;
  overflow: hidden;
  padding: 0 18px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  transition: max-height 0.25s ease, padding 0.25s ease;
}
.rpc-body.open { max-height: 1000px; padding: 18px; }
.rpc-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rpc-toggle-row label {
  font-size: 0.78rem;
  color: #4ade80;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 600;
}

/* ── ADMIN BADGE ── */
.admin-badge {
  background: #4ade80;
  color: #0f0f0f;
  font-size: 0.65rem;
  font-weight: 800;
  padding: 2px 8px;
  border-radius: 999px;
  margin-left: 8px;
  vertical-align: middle;
  letter-spacing: 0.05em;
}

/* ── ADMIN FILE PAGE ── */
.admin-page {
  display: none;
  position: fixed;
  inset: 0;
  background: #0a0a0a;
  z-index: 300;
  overflow-y: auto;
}
.admin-page.active { display: block; }

.admin-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 28px;
  background: #141414;
  border-bottom: 2px solid #fbbf2444;
  position: sticky;
  top: 0;
  z-index: 10;
}
.admin-topbar-title {
  font-size: 1rem;
  font-weight: 700;
  color: #fbbf24;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.admin-close-btn {
  background: transparent;
  border: 1px solid #333;
  color: #888;
  padding: 7px 16px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.85rem;
  transition: all 0.2s;
}
.admin-close-btn:hover { border-color: #f87171; color: #f87171; }

.admin-content {
  padding: 36px 32px;
  max-width: 1100px;
  margin: 0 auto;
}

.admin-section-title {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: #fbbf24;
  border-bottom: 1px solid #fbbf2422;
  padding-bottom: 8px;
  margin-bottom: 22px;
}

/* v3 GRID: 2 columns on desktop for token cards */
.token-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
  margin-bottom: 52px;
}

.token-card {
  background: #141414;
  border: 1px solid #222;
  border-radius: 10px;
  padding: 18px 20px;
  transition: border-color 0.2s;
}
.token-card:hover { border-color: #333; }

.token-card-name {
  font-size: 0.95rem;
  font-weight: 700;
  color: #f0f0f0;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.badge-user {
  font-size: 0.58rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  background: #222;
  color: #666;
  letter-spacing: 0.06em;
}
.badge-admin {
  font-size: 0.58rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  background: #4ade8018;
  color: #4ade80;
  letter-spacing: 0.06em;
}
.token-rows { display: flex; flex-direction: column; gap: 7px; }
.token-row {
  display: flex;
  gap: 8px;
  align-items: baseline;
  font-size: 0.82rem;
}
.token-row-key {
  min-width: 90px;
  color: #555;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.token-row-val {
  color: #bbb;
  font-family: 'Courier New', monospace;
  word-break: break-all;
  flex: 1;
  font-size: 0.82rem;
}
.token-row-val.empty { color: #333; font-style: italic; font-family: 'Segoe UI', sans-serif; font-size: 0.78rem; }
.inv-on  { color: #4ade80; font-weight: 700; font-size: 0.82rem; }
.inv-off { color: #444; font-size: 0.82rem; }

/* v3 Account list — 3-col grid on desktop */
.account-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 12px;
}
.account-item {
  background: #141414;
  border: 1px solid #222;
  border-radius: 8px;
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.account-item-name {
  font-size: 0.9rem;
  font-weight: 700;
  color: #f0f0f0;
  margin-bottom: 4px;
}
.account-detail-row {
  display: flex;
  gap: 8px;
  font-size: 0.8rem;
  align-items: baseline;
}
.account-detail-key {
  min-width: 88px;
  color: #555;
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  font-weight: 600;
}
.account-detail-val {
  color: #999;
  font-family: 'Courier New', monospace;
  flex: 1;
  word-break: break-all;
  font-size: 0.8rem;
}
.account-detail-val.pw { color: #f87171; }

/* ── MOBILE ── */
@media (max-width: 600px) {
  nav { padding: 12px 16px; }
  .nav-links button { padding: 7px 14px; font-size: 0.82rem; }
  .modal { padding: 24px 20px; }
  .admin-content { padding: 20px 14px; }
  .admin-topbar { padding: 13px 14px; }
  .token-cards { grid-template-columns: 1fr; }
  .account-list { grid-template-columns: 1fr; }
  .token-row { flex-direction: column; gap: 1px; }
  .token-row-key { min-width: unset; }
}
