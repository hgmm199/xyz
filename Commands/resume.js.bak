module.exports = async (client, message, state, channel) => {
  if (message.content !== "TT") return;

  if (!state.paused && !state.captcha) {
    console.log("▶️ Bot đang chạy rồi");
    return;
  }

  state.paused = false;
  state.captcha = false;
  await message.edit("RESUME");
  console.log("▶️ Resume — loop restart");

  if (typeof state.restartLoops === "function") {
    state.restartLoops();
  } else {
    console.log("❌ restartLoops chưa được gắn vào state");
  }
};